{
  "name": "novelpilot",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "backend:dev": "python -m uvicorn app.main:app --app-dir backend --reload",
    "backend:lint": "python -m ruff check backend",
    "backend:test": "python -m pytest backend/tests",
    "backend:typecheck": "python -m mypy backend",
    "frontend:dev": "npm.cmd --prefix frontend run dev",
    "frontend:lint": "npm.cmd --prefix frontend run lint",
    "frontend:test": "npm.cmd --prefix frontend run test",
    "frontend:build": "npm.cmd --prefix frontend run build",
    "frontend:typecheck": "npm.cmd --prefix frontend run typecheck",
    "acceptance": "python scripts/acceptance_report.py",
    "profile:upsert": "python scripts/configure_llm_profile.py",
    "profile:test": "python scripts/test_llm_profile.py",
    "smoke:live": "python scripts/live_provider_smoke.py",
    "audit:secrets": "python scripts/audit_output_secrets.py",
    "review:literary": "python scripts/record_literary_review.py",
    "audit:completion": "python scripts/completion_audit.py",
    "lint": "npm.cmd run backend:lint && npm.cmd run frontend:lint",
    "typecheck": "npm.cmd run backend:typecheck && npm.cmd run frontend:typecheck",
    "test": "npm.cmd run backend:test && npm.cmd run frontend:test"
  }
}
