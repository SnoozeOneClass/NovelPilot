{
  "name": "novelpilot",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "backend:dev": "scripts\\python.cmd -m uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port 8010 --reload",
    "backend:migrate": "scripts\\python.cmd scripts/database_admin.py migrate",
    "backend:migrate:test": "scripts\\python.cmd scripts/database_admin.py migrate-test",
    "backend:schema-check": "scripts\\python.cmd scripts/database_admin.py check",
    "backend:backup": "scripts\\python.cmd scripts/database_admin.py backup",
    "backend:backup:validate": "scripts\\python.cmd scripts/database_admin.py validate-backup",
    "backend:restore": "scripts\\python.cmd scripts/database_admin.py restore",
    "backend:lint": "scripts\\python.cmd -m ruff check backend scripts",
    "backend:test": "scripts\\python.cmd -m pytest backend/tests",
    "backend:typecheck": "scripts\\python.cmd -m mypy backend",
    "frontend:dev": "npm.cmd --prefix frontend run dev",
    "frontend:lint": "npm.cmd --prefix frontend run lint",
    "frontend:test": "npm.cmd --prefix frontend run test",
    "frontend:build": "npm.cmd --prefix frontend run build",
    "frontend:typecheck": "npm.cmd --prefix frontend run typecheck",
    "acceptance": "scripts\\python.cmd scripts/acceptance_report.py",
    "profile:migrate": "scripts\\python.cmd scripts/migrate_profile_config.py",
    "audit:secrets": "scripts\\python.cmd scripts/audit_runtime_secrets.py",
    "observe:live-book-series": "scripts\\python.cmd scripts/live_book_observation_series.py",
    "lint": "npm.cmd run backend:lint && npm.cmd run frontend:lint",
    "typecheck": "npm.cmd run backend:typecheck && npm.cmd run frontend:typecheck",
    "test": "npm.cmd run backend:test && npm.cmd run frontend:test"
  }
}
