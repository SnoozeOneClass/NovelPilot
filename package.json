{
  "name": "novelpilot",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "backend:dev": ".venv\\python.exe -m uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port 8010 --reload",
    "backend:lint": ".venv\\python.exe -m ruff check backend",
    "backend:test": ".venv\\python.exe -m pytest backend/tests",
    "backend:typecheck": ".venv\\python.exe -m mypy backend",
    "frontend:dev": "npm.cmd --prefix frontend run dev",
    "frontend:lint": "npm.cmd --prefix frontend run lint",
    "frontend:test": "npm.cmd --prefix frontend run test",
    "frontend:build": "npm.cmd --prefix frontend run build",
    "frontend:typecheck": "npm.cmd --prefix frontend run typecheck",
    "acceptance": ".venv\\python.exe scripts/acceptance_report.py",
    "profile:upsert": ".venv\\python.exe scripts/configure_llm_profile.py",
    "profile:test": ".venv\\python.exe scripts/test_llm_profile.py",
    "smoke:live": ".venv\\python.exe scripts/live_provider_smoke.py",
    "audit:secrets": ".venv\\python.exe scripts/audit_output_secrets.py",
    "review:literary": ".venv\\python.exe scripts/record_literary_review.py",
    "audit:completion": ".venv\\python.exe scripts/completion_audit.py",
    "lint": "npm.cmd run backend:lint && npm.cmd run frontend:lint",
    "typecheck": "npm.cmd run backend:typecheck && npm.cmd run frontend:typecheck",
    "test": "npm.cmd run backend:test && npm.cmd run frontend:test"
  }
}
