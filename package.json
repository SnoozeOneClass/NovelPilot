{
  "name": "novelpilot",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "backend:dev": "scripts\\python.cmd -m uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port 8010 --reload",
    "backend:lint": "scripts\\python.cmd -m ruff check backend",
    "backend:test": "scripts\\python.cmd -m pytest backend/tests",
    "backend:typecheck": "scripts\\python.cmd -m mypy backend",
    "frontend:dev": "npm.cmd --prefix frontend run dev",
    "frontend:lint": "npm.cmd --prefix frontend run lint",
    "frontend:test": "npm.cmd --prefix frontend run test",
    "frontend:build": "npm.cmd --prefix frontend run build",
    "frontend:typecheck": "npm.cmd --prefix frontend run typecheck",
    "acceptance": "scripts\\python.cmd scripts/acceptance_report.py",
    "profile:upsert": "scripts\\python.cmd scripts/configure_llm_profile.py",
    "profile:test": "scripts\\python.cmd scripts/test_llm_profile.py",
    "smoke:live": "scripts\\python.cmd scripts/live_provider_smoke.py",
    "audit:secrets": "scripts\\python.cmd scripts/audit_output_secrets.py",
    "review:literary": "scripts\\python.cmd scripts/record_literary_review.py",
    "audit:completion": "scripts\\python.cmd scripts/completion_audit.py",
    "lint": "npm.cmd run backend:lint && npm.cmd run frontend:lint",
    "typecheck": "npm.cmd run backend:typecheck && npm.cmd run frontend:typecheck",
    "test": "npm.cmd run backend:test && npm.cmd run frontend:test"
  }
}
